{
  "profile": "codex-web",
  "actions": [
    {
      "id": "web-agents",
      "src": "web/codex/AGENTS.md",
      "target": "agents",
      "strategy": "append_block"
    },
    {
      "id": "web-codex-config",
      "src": "web/codex/config.toml",
      "target": "codex_config",
      "strategy": "merge_toml_keys"
    },
    {
      "id": "web-skills",
      "src": "web/skills",
      "target": "skills_dir",
      "strategy": "sync_additive_dir"
    }
  ]
}
