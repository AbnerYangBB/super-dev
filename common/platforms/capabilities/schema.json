{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Platform Capability Matrix",
  "type": "object",
  "required": [
    "platform",
    "verified_at",
    "capabilities"
  ],
  "properties": {
    "platform": {
      "type": "string"
    },
    "verified_at": {
      "type": "string",
      "description": "UTC date in YYYY-MM-DD"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "support",
          "config_path",
          "fallback",
          "source_url",
          "purpose"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "support": {
            "type": "string",
            "enum": [
              "supported",
              "unsupported",
              "fallback_required"
            ]
          },
          "config_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "fallback": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          },
          "source_url": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
