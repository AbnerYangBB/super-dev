      {
        "platform": "claude-code",
        "operation": "merge_json_keys",
        "target": ".claude/settings.json"
      }
    ],
    "expected_changed_files": [],
    "evidence_patterns": [
      "npm run lint"
    ]
  },
  {
    "id": "shared_instruction",
    "prompt": "增加一条通用 instruction: 所有回复必须使用中文",
    "expected_actions": [
      {
        "platform": "claude-code",
        "operation": "append_block",
        "target": "CLAUDE.md"
      },
      {
        "platform": "codex-cli",
        "operation": "append_block",
        "target": "AGENTS.md"
      }
    ],
    "expected_changed_files": [
