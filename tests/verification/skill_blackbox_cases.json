[
  {
    "id": "pre_commit_loc",
    "prompt": "增加一个 Hook: 提交前使用 sync-add-ios-loc 做本地化校验",
    "expected_actions": [
      {
        "platform": "claude-code",
        "operation": "merge_json_keys",
        "target": ".claude/settings.json"
      },
      {
        "platform": "codex-cli",
        "operation": "append_block",
        "target": "AGENTS.md"
      }
    ],
    "expected_changed_files": [
      "ios/codex/AGENTS.md"
    ],
    "evidence_patterns": [
      "sync-add-ios-loc"
    ]
  },
  {
    "id": "add_mcp_server",
    "prompt": "增加一个 MCP server: example-server",
    "expected_actions": [
      {
        "platform": "claude-code",
        "operation": "merge_json_keys",
        "target": ".mcp.json"
      },
      {
        "platform": "codex-cli",
        "operation": "merge_toml_keys",
        "target": ".codex/config.toml"
      }
    ],
    "expected_changed_files": [
      "ios/claude/mcp.json",
      "ios/codex/config.toml"
    ],
    "evidence_patterns": [
      "example-server"
    ]
  },
  {
    "id": "add_mcp_server_custom_codex_only",
