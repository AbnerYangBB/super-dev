      {
        "platform": "codex-cli",
        "operation": "merge_toml_keys",
        "target": ".codex/config.toml"
      }
    ],
    "expected_changed_files": [
      "ios/codex/config.toml"
    ],
    "evidence_patterns": [
      "lint-server",
      "uvx"
    ]
  },
  {
    "id": "hook_custom_command_claude_only",
    "prompt": "增加一个 hook: 提交前执行 command: npm run lint 仅 claude",
