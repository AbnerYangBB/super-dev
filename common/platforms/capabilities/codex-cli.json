{
  "platform": "codex-cli",
  "verified_at": "2026-03-02",
  "capabilities": [
    {
      "id": "context_memory",
      "support": "supported",
      "config_path": "AGENTS.md",
      "fallback": "none",
      "purpose": "沉淀项目长期指令与约束",
      "source_url": "https://github.com/openai/codex/blob/main/docs/agents.md",
      "notes": "支持 global/root/subdir 优先级"
    },
    {
      "id": "hooks",
      "support": "fallback_required",
      "config_path": null,
      "fallback": "append_instruction_block",
      "purpose": "在关键时机触发校验或策略",
      "source_url": "https://github.com/openai/codex/blob/main/docs/config.md",
      "notes": "官方文档未提供 hook 配置键，使用 AGENTS 指令回退"
    },
    {
      "id": "skills",
      "support": "supported",
      "config_path": "./codex/skills",
      "fallback": "none",
      "purpose": "复用结构化能力包",
      "source_url": "https://github.com/openai/codex/blob/main/docs/agents.md",
      "notes": "也支持 ~/.codex/skills"
    },
    {
      "id": "command_ext",
      "support": "supported",
      "config_path": "~/.codex/prompts",
      "fallback": "append_instruction_block",
      "purpose": "快速触发预设动作模板",
      "source_url": "https://github.com/openai/codex/blob/main/docs/prompting.md",
      "notes": "交互模式下支持 /help 命令"
    },
    {
      "id": "subagents",
      "support": "fallback_required",
      "config_path": null,
      "fallback": "append_process_instruction",
      "purpose": "复杂任务拆分",
      "source_url": "https://github.com/openai/codex/blob/main/docs/agents.md",
      "notes": "官方文档未见等价子代理配置文件能力"
    },
    {
      "id": "mcp",
      "support": "supported",
      "config_path": "~/.codex/config.toml#[mcp_servers.<name>]",
      "fallback": "none",
      "purpose": "接入外部 MCP 工具",
      "source_url": "https://github.com/openai/codex/blob/main/docs/config.md",
      "notes": "通过 config.toml 配置 MCP 服务器"
    },
    {
      "id": "security",
      "support": "supported",
      "config_path": "~/.codex/config.toml#sandbox_mode,approval_policy",
      "fallback": "none",
      "purpose": "控制命令执行边界",
      "source_url": "https://github.com/openai/codex/blob/main/docs/config.md",
      "notes": "支持 read-only/workspace-write/danger-full-access 等模式"
    }
  ]
}
